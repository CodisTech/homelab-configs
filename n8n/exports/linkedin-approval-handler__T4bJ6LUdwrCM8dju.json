    {
      "id": "b2000001-0000-0000-0000-000000000007",
      "name": "Update Tracking Approved",
      "parameters": {
        "jsCode": "const binaryData = $input.item.binary.trackingFile;\nconst rawContent = Buffer.from(binaryData.data, 'base64').toString('utf-8');\nconst tracking = JSON.parse(rawContent);\nconst postId = $('Parse Callback Data').item.json.postId;\n\n// Find the entry and update status\nconst entry = tracking.processedFiles.find(f => f.postId === postId);\nif (entry) {\n  entry.status = 'approved';\n  entry.approvedDate = new Date().toISOString();\n}\ntracking.lastUpdated = new Date().toISOString();\n\nreturn [{ json: { trackingContent: JSON.stringify(tracking, null, 2), postId } }];"
      },
