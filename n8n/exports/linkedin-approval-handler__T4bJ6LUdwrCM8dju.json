      "id": "b2000001-0000-0000-0000-000000000002",
      "name": "Parse Callback Data",
      "parameters": {
        "jsCode": "const callbackData = $input.item.json.callback_query.data;\nconst callbackQueryId = $input.item.json.callback_query.id;\nconst chatId = $input.item.json.callback_query.message.chat.id;\n\n// Parse action and postId from callback_data like \"approve_post_1706464800\" or \"deny_post_1706464800\"\nlet action, postId;\nif (callbackData.startsWith('approve_')) {\n  action = 'approve';\n  postId = callbackData.replace('approve_', '');\n} else if (callbackData.startsWith('deny_')) {\n  action = 'deny';\n  postId = callbackData.replace('deny_', '');\n} else {\n  throw new Error('Unknown callback action: ' + callbackData);\n}\n\nreturn [{ json: { action, postId, callbackQueryId, chatId } }];"
      },
