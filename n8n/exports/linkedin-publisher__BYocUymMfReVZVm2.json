    {
      "id": "c3000001-0000-0000-0000-000000000003",
      "name": "Find Approved Posts",
      "parameters": {
        "jsCode": "const xml = $input.item.json.data;\n\n// Extract directory entries from WebDAV response\nconst responsePattern = /<d:response>[\\s\\S]*?<d:href>([^<]+)<\\/d:href>[\\s\\S]*?<\\/d:response>/g;\nconst folders = [];\nlet match;\n\nwhile ((match = responsePattern.exec(xml)) !== null) {\n  const href = decodeURIComponent(match[1]);\n  // Look for post_ folders (skip the Approved/ folder itself)\n  const postMatch = href.match(/Approved\\/(post_\\d+)\\/?$/);\n  if (postMatch) {\n    folders.push(postMatch[1]);\n  }\n}\n\nif (folders.length === 0) {\n  return [{ json: { hasPost: false, message: 'No approved posts available for publishing' } }];\n}\n\n// Pick the first (oldest) approved post\nconst postId = folders.sort()[0];\n\nreturn [{ json: { hasPost: true, postId } }];"
      },
      "position": [
        360,
        0
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
