        "jsCode": "const postContent = $input.item.binary.postContent;\nconst postText = Buffer.from(postContent.data, 'base64').toString('utf-8');\nconst postId = $('Find Approved Posts').item.json.postId;\n\n// Pass through the image binary as 'data'\nreturn [{\n  json: { postText, postId },\n  binary: { data: $input.item.binary.data }\n}];"
