      "id": "parse-callback",
      "name": "Parse Callback",
      "notes": "Extracts approval decision and post info from callback",
      "parameters": {
        "jsCode": "const callbackData = $input.first().json.callback_query?.data || '';\nconst isApproved = callbackData.startsWith('py_approve_');\nconst postNumber = parseInt(callbackData.split('_').pop(), 10);\n\nlet postFile, imageFile, dayLabel;\nif (postNumber === 0) {\n  postFile = 'launch.md';\n  imageFile = 'protect-yourself-launch.png';\n  dayLabel = 'Launch';\n} else {\n  const dayNum = postNumber.toString().padStart(2, '0');\n  postFile = `day${dayNum}.md`;\n  imageFile = `protect-yourself-day${dayNum}.png`;\n  dayLabel = `Day ${postNumber}`;\n}\n\nreturn [{\n  isApproved,\n  postNumber,\n  postFile,\n  imageFile,\n  dayLabel,\n  nextPostNumber: postNumber + 1,\n  callbackData\n}];"
      },
      "position": [
        2200,
