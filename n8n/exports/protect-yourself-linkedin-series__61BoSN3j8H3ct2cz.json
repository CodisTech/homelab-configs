    {
      "id": "determine-post",
      "name": "Determine Next Post",
      "notes": "Calculates which post to send based on tracker file",
      "parameters": {
        "jsCode": "// Get current post number from tracker (0 = launch, 1-20 = day01-day20)\nlet postNumber = 0;\n\ntry {\n  const trackerContent = $input.first().json.data || $input.first().json.body || '';\n  postNumber = parseInt(trackerContent.toString().trim(), 10);\n  if (isNaN(postNumber)) postNumber = 0;\n} catch (e) {\n  postNumber = 0;\n}\n\n// Check if series is complete\nif (postNumber > 20) {\n  return [{\n    seriesComplete: true,\n    postNumber: postNumber,\n    message: '\ud83c\udf89 The Protect Yourself series is complete! All 21 posts have been published.'\n  }];\n}\n\n// Determine file names\nlet postFile, imageFile, dayLabel;\n\nif (postNumber === 0) {\n  postFile = 'launch.md';\n  imageFile = 'protect-yourself-launch.png';\n  dayLabel = 'Launch';\n} else {\n  const dayNum = postNumber.toString().padStart(2, '0');\n  postFile = `day${dayNum}.md`;\n  imageFile = `protect-yourself-day${dayNum}.png`;\n  dayLabel = `Day ${postNumber} of 20`;\n}\n\nconst basePath = '/Personal/LinkedIn/protect_yourself';\nconst webdavBase = 'https://nextcloud.local.example.home/remote.php/webdav';\n\nreturn [{\n  seriesComplete: false,\n  postNumber: postNumber,\n  dayLabel: dayLabel,\n  postFile: postFile,\n  imageFile: imageFile,\n  postPath: `${basePath}/posts/${postFile}`,\n  imagePath: `${basePath}/images/${imageFile}`,\n  postUrl: `${webdavBase}${basePath}/posts/${postFile}`,\n  imageUrl: `${webdavBase}${basePath}/images/${imageFile}`,\n  publishedPath: `${basePath}/published/${postFile}`,\n  callbackApprove: `py_approve_${postNumber}`,\n  callbackReject: `py_reject_${postNumber}`\n}];"
      },
      "position": [
        440,
        300
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
