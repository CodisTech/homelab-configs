      "name": "Prepare Telegram Message",
      "notes": "Formats the Telegram approval message",
      "parameters": {
        "jsCode": "const postData = $('Determine Next Post').first().json;\nconst postContent = $('Fetch Post Content').first().json.data || $('Fetch Post Content').first().json.body || '';\n\n// Format the message\nconst message = `\ud83d\udee1\ufe0f PROTECT YOURSELF \u2014 ${postData.dayLabel}\n\n${postContent.trim()}\n\n---\n\ud83d\udcce Image attached above\n\ud83d\udcc5 Post #${postData.postNumber} ready for approval\n\nApprove to save to Published folder.`;\n\nreturn [{\n  ...postData,\n  postContent: postContent,\n  telegramMessage: message\n}];"
      },
