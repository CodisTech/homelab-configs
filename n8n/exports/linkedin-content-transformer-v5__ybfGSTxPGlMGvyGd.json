      "id": "v5-find-source",
      "name": "Find Source Document",
      "parameters": {
        "jsCode": "const xml = $input.item.json.data;\nconst responsePattern = /<d:response>[\\s\\S]*?<d:href>([^<]+)<\\/d:href>[\\s\\S]*?<\\/d:response>/gi;\nconst files = [];\nlet match;\nwhile ((match = responsePattern.exec(xml)) !== null) {\n  const href = decodeURIComponent(match[1]);\n  if (href.match(/\\.(md|docx)$/i)) {\n    const pathMatch = href.match(/\\/remote\\.php\\/webdav\\/(.+)/);\n    if (pathMatch) { files.push('/' + pathMatch[1]); }\n  }\n}\nif (files.length === 0) {\n  return [{ json: { hasFile: false, message: 'No source documents found in Pending_Review' } }];\n}\nconst selectedFile = files[0];\nconst fileName = selectedFile.split('/').pop();\nreturn [{ json: { hasFile: true, selectedFile, fileName, totalFiles: files.length } }];"
      },
