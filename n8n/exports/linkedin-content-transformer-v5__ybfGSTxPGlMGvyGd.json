    {
      "id": "v5-load-past-posts",
      "name": "Load Past Posts",
      "parameters": {
        "jsCode": "const xml = $input.item.json.data || '';\nconst content = $('Extract Content').item.json.content;\nconst fileName = $('Extract Content').item.json.fileName;\nconst selectedFile = $('Extract Content').item.json.selectedFile;\n\n// Parse published file names from WebDAV XML\nconst responsePattern = /<d:response>[\\s\\S]*?<d:href>([^<]+)<\\/d:href>[\\s\\S]*?<\\/d:response>/gi;\nconst publishedFiles = [];\nlet match;\n\nwhile ((match = responsePattern.exec(xml)) !== null) {\n  const href = decodeURIComponent(match[1]);\n  if (href.match(/\\.(txt|md)$/i)) {\n    const name = href.split('/').pop();\n    publishedFiles.push(name);\n  }\n}\n\n// Build a summary of past topics from file names\nlet pastTopics = 'None yet.';\nif (publishedFiles.length > 0) {\n  // Take the last 20 file names as topic hints\n  const recent = publishedFiles.slice(-20);\n  pastTopics = recent.map(f => f.replace(/\\.(txt|md)$/i, '').replace(/_/g, ' ')).join(', ');\n}\n\nreturn [{ json: { content, fileName, selectedFile, pastTopics, publishedCount: publishedFiles.length } }];"
      },
