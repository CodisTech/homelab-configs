      "id": "v5-extract",
      "name": "Extract Content",
      "parameters": {
        "jsCode": "const rawContent = $input.item.json.data;\n\n// Check if download returned content\nif (!rawContent) {\n  throw new Error('Download failed - no content returned. File may not exist or credentials may be invalid. Selected file: ' + $('Find Source Document').item.json.selectedFile);\n}\n\nconst selectedFile = $('Find Source Document').item.json.selectedFile;\nconst fileName = $('Find Source Document').item.json.fileName;\nconst content = rawContent.substring(0, 15000);\nconst wasTruncated = rawContent.length > 15000;\n\nreturn [{ json: { content, fileName, selectedFile, wasTruncated, originalLength: rawContent.length } }];"
      },
