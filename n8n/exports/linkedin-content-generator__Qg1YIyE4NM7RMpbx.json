    {
      "id": "a1000001-0000-0000-0000-000000000007",
      "name": "Parse Claude Response",
      "parameters": {
        "jsCode": "const response = $input.item.json;\nconst selectedFile = $('Build Claude Prompt').item.json.selectedFile;\nconst postId = $('Build Claude Prompt').item.json.postId;\n\nlet claudeText = '';\nif (response.content && response.content.length > 0) {\n  claudeText = response.content[0].text;\n}\n\n// Extract JSON from Claude's response (handle markdown code blocks)\nlet parsed;\ntry {\n  // Try direct parse first\n  parsed = JSON.parse(claudeText);\n} catch (e) {\n  // Try extracting from code block\n  const jsonMatch = claudeText.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n  if (jsonMatch) {\n    parsed = JSON.parse(jsonMatch[1].trim());\n  } else {\n    // Try finding JSON object in text\n    const objMatch = claudeText.match(/\\{[\\s\\S]*\\}/);\n    if (objMatch) {\n      parsed = JSON.parse(objMatch[0]);\n    } else {\n      throw new Error('Could not parse Claude response as JSON: ' + claudeText.substring(0, 200));\n    }\n  }\n}\n\nreturn [{\n  json: {\n    postText: parsed.postText,\n    imagePrompt: parsed.imagePrompt,\n    hashtags: parsed.hashtags || [],\n    topicSummary: parsed.topicSummary || '',\n    selectedFile,\n    postId\n  }\n}];"
