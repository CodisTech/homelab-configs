    {
      "id": "a1000001-0000-0000-0000-000000000003",
      "name": "Select Unprocessed File",
      "parameters": {
        "jsCode": "// Parse WebDAV XML response to find .md files, cross-reference with tracking\nconst xml = $input.item.json.data;\nconst tracking = $('Parse Tracking Data').item.json.tracking;\nconst processedPaths = tracking.processedFiles.map(f => f.sourcePath);\n\n// Extract all href entries from WebDAV response\nconst responsePattern = /<d:response>[\\s\\S]*?<d:href>([^<]+)<\\/d:href>[\\s\\S]*?<\\/d:response>/g;\nconst files = [];\nlet match;\n\nwhile ((match = responsePattern.exec(xml)) !== null) {\n  const href = decodeURIComponent(match[1]);\n  // Only include .md files (not directories)\n  if (href.endsWith('.md')) {\n    // Extract the path relative to webdav root\n    const pathMatch = href.match(/\\/remote\\.php\\/webdav\\/(.+)/);\n    if (pathMatch) {\n      const filePath = '/' + pathMatch[1];\n      if (!processedPaths.includes(filePath)) {\n        files.push(filePath);\n      }\n    }\n  }\n}\n\nif (files.length === 0) {\n  return [{ json: { hasFile: false, message: 'All source files have been processed' } }];\n}\n\n// Pick the first unprocessed file\nconst selectedFile = files[0];\nconst postId = 'post_' + Date.now();\n\nreturn [{ json: { hasFile: true, selectedFile, postId, remainingFiles: files.length } }];"
      },
      "position": [
        800,
        0
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
