      "parameters": {
        "jsCode": "// Parse tracking.json from binary\nconst binaryData = $input.item.binary.trackingFile;\nlet trackingData;\n\ntry {\n  const rawContent = Buffer.from(binaryData.data, 'base64').toString('utf-8');\n  trackingData = JSON.parse(rawContent);\n} catch (e) {\n  trackingData = { processedFiles: [], lastUpdated: '' };\n}\n\nreturn [{ json: { tracking: trackingData } }];"
