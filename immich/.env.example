# Immich env — example. Live env at /home/serveradmin/docker_volumes/immich/.env on VM 100.
# Pin specific version, never :release / :latest (Immich version-sensitive).
IMMICH_VERSION=v2.7.5

UPLOAD_LOCATION=/mnt/immich-library
DB_DATA_LOCATION=/home/serveradmin/docker_volumes/immich/postgres
TZ=America/New_York

DB_PASSWORD=<openssl-rand-hex-24>
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
