# Hosts
PROMETHEUS_HOST=prometheus.example.com
GRAFANA_HOST=grafana.example.com
AUTHENTIK_HOST=auth.example.com

# Grafana OAuth (Authentik)
GRAFANA_OAUTH_CLIENT_ID=your-client-id
GRAFANA_OAUTH_CLIENT_SECRET=your-client-secret

# Pi-hole Exporter
PIHOLE_IP=10.0.0.x
PIHOLE_PASSWORD=your-pihole-password

# Proxmox Exporter — credentials moved to config_pve_exporter/pve.yml
# See config_pve_exporter/pve.yml.example for the multi-module template.